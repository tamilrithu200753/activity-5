def subsets(nums):
    result = []

    def backtrack(start, path):
        result.append(path[:])  # add current subset
        for i in range(start, len(nums)):
            path.append(nums[i])
            backtrack(i + 1, path)  # move to next element
            path.pop()  # backtrack

    backtrack(0, [])
    return result

# Example usage
nums = [1, 2, 3]
print(subsets(nums))
# Output: [[], [1], [1, 2], [1, 2, 3], [1, 3], [2], [2, 3], [3]]
